# Skill Gap Analyzer - Environment Template
# Copy this file to .env and fill in the values

# Groq API Key for AI-powered roadmaps and RAG verification
# Get one at https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Backend Config
PROJECT_NAME="Generative Skill Gap Analyzer"
VERSION="1.0.0"

# Optional: Qdrant Config (defaults to local file-based storage)
# For local use, leave these empty. For Qdrant Cloud, provide values:
QDRANT_URL=
QDRANT_API_KEY=
# QDRANT_HOST=localhost
# QDRANT_PORT=6333

# Google OAuth Config
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:8000/api/v1/auth/callback

# MongoDB Config
# For local MongoDB, use: mongodb://localhost:27017
# For MongoDB Atlas, use your connection string
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=skill_gap_analyzer

# JWT Config
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_EXPIRATION_HOURS=72

# Frontend URL (for OAuth redirect after login)
FRONTEND_URL=http://localhost:5173
